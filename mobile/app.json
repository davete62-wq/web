{
  "expo": {
    "name": "TenaFit",
    "slug": "tenafit",
    "scheme": "tenafit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tenafit.app",
      "adaptiveIcon": {
        "backgroundColor": "#f7fbf8"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
