{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "preview": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://replace-with-your-render-backend-url.onrender.com"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://replace-with-your-render-backend-url.onrender.com"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
